#!/usr/bin/env python3
"""Assemble the single-file TSO Resources deliverable from modular sources."""

from __future__ import annotations

import argparse
from datetime import datetime, timedelta, timezone
import json
import os
import re
import subprocess
import tempfile
from pathlib import Path


ROOT = Path(__file__).resolve().parent
APP_JS_SOURCES = [
    "src/js/00-index.js",
    "src/js/10-utilities.js",
    "src/js/20-normalization.js",
    "src/js/30-state.js",
    "src/js/40-safety.js",
    "src/js/50-rendering.js",
    "src/js/60-undo-and-views.js",
    "src/js/70-print.js",
    "src/js/80-admin-shell.js",
    "src/js/90-persistence-and-packages.js",
    "src/js/100-admin-editors.js",
    "src/js/110-shortcuts.js",
    "src/js/120-startup.js",
]
PLACEHOLDERS = [
    "{{APP_CSS}}",
    "{{TEST_UI}}",
    "{{SEED_DATA}}",
    "{{APP_RELEASE_DATA}}",
    "{{VENDOR_JS}}",
    "{{APP_JS}}",
    "{{TEST_JS}}",
]


def load_release() -> dict[str, object]:
    try:
        release = json.loads(read("src/release.json"))
    except json.JSONDecodeError as error:
        raise SystemExit(f"Invalid src/release.json: {error}") from error
    if not isinstance(release, dict):
        raise SystemExit("src/release.json must contain one JSON object")
    normalized = {
        "version": str(release.get("version", "")).strip(),
        "date": str(release.get("date", "")).strip(),
        "message": str(release.get("message", "")).strip(),
        "includedCommits": [
            str(commit_hash).strip()
            for commit_hash in release.get("includedCommits", [])
        ] if isinstance(release.get("includedCommits", []), list) else [],
    }
    if not re.fullmatch(r"\d+\.\d+\.\d+", normalized["version"]):
        raise SystemExit("src/release.json version must use major.minor.patch format")
    try:
        datetime.strptime(normalized["date"], "%Y-%m-%d")
    except ValueError as error:
        raise SystemExit("src/release.json date must use YYYY-MM-DD format") from error
    if not normalized["message"]:
        raise SystemExit("src/release.json message must not be blank")
    if any(not re.fullmatch(r"[0-9a-f]{40}", commit_hash) for commit_hash in normalized["includedCommits"]):
        raise SystemExit("src/release.json includedCommits must contain full lowercase Git commit IDs")
    return normalized


def read_recent_git_commits() -> list[dict[str, str]]:
    result = subprocess.run(
        ["git", "log", "--format=%H%x00%cI%x00%s", "--since=15.days.ago"],
        cwd=ROOT,
        check=False,
        capture_output=True,
        text=True,
    )
    if result.returncode != 0:
        return []
    commits = []
    for line in result.stdout.splitlines():
        parts = line.split("\0", 2)
        if len(parts) != 3:
            continue
        commit_hash, timestamp, message = parts
        if not message.strip():
            continue
        try:
            committed_at = datetime.fromisoformat(timestamp).astimezone(timezone.utc)
        except ValueError:
            continue
        commits.append({
            "hash": commit_hash,
            "timestamp": committed_at.isoformat(),
            "message": message.strip(),
        })
    return commits


def merge_app_changes(
    release: dict[str, object],
    commits: list[dict[str, str]],
    now: datetime | None = None,
) -> list[dict[str, str]]:
    current_time = now or datetime.now(timezone.utc)
    if current_time.tzinfo is None:
        current_time = current_time.replace(tzinfo=timezone.utc)
    cutoff = current_time.astimezone(timezone.utc) - timedelta(days=14)
    included_commits = set(release.get("includedCommits", []))
    changes = []
    for commit in commits:
        commit_hash = str(commit.get("hash", "")).strip()
        message = str(commit.get("message", "")).strip()
        try:
            committed_at = datetime.fromisoformat(str(commit.get("timestamp", ""))).astimezone(timezone.utc)
        except ValueError:
            continue
        if committed_at < cutoff or not message or commit_hash not in included_commits:
            continue
        changes.append({"date": committed_at.date().isoformat(), "message": message})
    return changes


def build_app_release_data() -> str:
    release = load_release()
    payload = {
        "version": release["version"],
        "changes": merge_app_changes(release, read_recent_git_commits()),
    }
    return json.dumps(payload, indent=2).replace("</", "<\\/")


def read(relative_path: str) -> str:
    path = ROOT / relative_path
    if not path.is_file():
        raise SystemExit(f"Missing build source: {relative_path}")
    return path.read_text(encoding="utf-8").rstrip()


def join_javascript(relative_paths: list[str]) -> str:
    sections = []
    for relative_path in relative_paths:
        sections.append(f"// Source: {relative_path}\n{read(relative_path)}")
    return "\n\n".join(sections)


def replace_placeholder(document: str, placeholder: str, value: str) -> str:
    count = document.count(placeholder)
    if count != 1:
        raise SystemExit(f"Expected one {placeholder} placeholder; found {count}")
    return document.replace(placeholder, value, 1)


def build_document(include_tests: bool) -> str:
    shell = read("src/app-shell.html")
    for placeholder in PLACEHOLDERS:
        if shell.count(placeholder) != 1:
            raise SystemExit(f"Expected one {placeholder} placeholder in src/app-shell.html")

    seed_text = read("src/seed-data.json")
    try:
        json.loads(seed_text)
    except json.JSONDecodeError as error:
        raise SystemExit(f"Invalid src/seed-data.json: {error}") from error
    if re.search(r"</script", seed_text, flags=re.IGNORECASE):
        raise SystemExit("src/seed-data.json must not contain a closing script tag")

    replacements = {
        "{{APP_CSS}}": read("src/styles.css"),
        "{{TEST_UI}}": read("tests/self-test-panel.html") if include_tests else "",
        "{{SEED_DATA}}": seed_text,
        "{{APP_RELEASE_DATA}}": build_app_release_data(),
        "{{VENDOR_JS}}": read("vendor/jszip.min.js"),
        "{{APP_JS}}": join_javascript(APP_JS_SOURCES),
        "{{TEST_JS}}": (
            "// Source: tests/self-tests.js\n" + read("tests/self-tests.js")
            if include_tests
            else ""
        ),
    }
    output = shell
    for placeholder, value in replacements.items():
        output = replace_placeholder(output, placeholder, value)

    unresolved = re.findall(r"{{[A-Z0-9_]+}}", output)
    if unresolved:
        raise SystemExit(f"Unresolved build placeholders: {', '.join(sorted(set(unresolved)))}")
    if not include_tests:
        forbidden = ["function runSelfTests", 'id="selfTestPanel"', "isSelfTestShortcut"]
        found = [token for token in forbidden if token in output]
        if found:
            raise SystemExit(f"Production build contains self-test code: {', '.join(found)}")
    return output.rstrip() + "\n"


def write_atomic(destination: Path, content: str) -> None:
    destination.parent.mkdir(parents=True, exist_ok=True)
    with tempfile.NamedTemporaryFile(
        mode="w",
        encoding="utf-8",
        dir=destination.parent,
        prefix=f".{destination.name}.",
        delete=False,
    ) as temporary:
        temporary.write(content)
        temporary_path = Path(temporary.name)
    os.replace(temporary_path, destination)


def main() -> int:
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument(
        "--with-tests",
        action="store_true",
        help="Include the browser self-test panel and Ctrl+Shift+T test harness",
    )
    parser.add_argument("--output", "-o", help="Output HTML path")
    parser.add_argument(
        "--check",
        action="store_true",
        help="Verify that the requested output is current without rewriting it",
    )
    args = parser.parse_args()

    default_output = "build/tso-resources-debug.html" if args.with_tests else "new.html"
    destination = Path(args.output or default_output)
    if not destination.is_absolute():
        destination = ROOT / destination
    content = build_document(args.with_tests)

    if args.check:
        if not destination.is_file() or destination.read_text(encoding="utf-8") != content:
            raise SystemExit(f"Generated output is not current: {destination}")
        print(f"Build output is current: {destination}")
        return 0

    write_atomic(destination, content)
    build_kind = "debug" if args.with_tests else "production"
    print(f"Wrote {build_kind} TSO Resources deliverable: {destination}")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
